# KestraVault self-host configuration.
#
# DO NOT edit this file — run ./setup.sh, which copies it to .env with fresh
# generated secrets (the __GENERATE__ values below). .env is gitignored.

############
# Secrets — generated by setup.sh. Never commit them.
############

POSTGRES_PASSWORD=__GENERATE__
JWT_SECRET=__GENERATE__
ANON_KEY=__GENERATE__
SERVICE_ROLE_KEY=__GENERATE__
SECRET_KEY_BASE=__GENERATE__

############
# URLs — THE self-host gotcha. These must be the URL your devices actually
# reach, or auth redirects and realtime silently break.
#
#   Tailscale path (recommended):  https://<TS_HOSTNAME>.<tailnet>.ts.net
#   LAN-only:                      http://<server-lan-ip>:8000
############

API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:8000
# Extra allowed auth redirect URLs, comma-separated (usually empty).
ADDITIONAL_REDIRECT_URLS=

############
# Database
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# API gateway
############

# Host port the stack listens on (http). The Tailscale sidecar serves this
# same gateway as https at your MagicDNS name.
KONG_HTTP_PORT=8000

############
# Auth
############

JWT_EXPIRY=3600
DISABLE_SIGNUP=false
# Without SMTP, keep autoconfirm on so sign-up needs no confirmation email.
ENABLE_EMAIL_AUTOCONFIRM=true

# Optional SMTP — fill these and set ENABLE_EMAIL_AUTOCONFIRM=false to require
# email confirmation.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=
SMTP_SENDER_NAME=KestraVault

############
# Data API / storage / functions
############

PGRST_DB_SCHEMAS=public,storage,graphql_public
# 50 MiB per file — raise if you drop big sources into your workspaces.
FILE_SIZE_LIMIT=52428800
FUNCTIONS_VERIFY_JWT=true

############
# Optional profiles
############

# --profile studio: admin UI on 127.0.0.1:<STUDIO_PORT> (server-local only).
STUDIO_PORT=3000

# --profile tailscale: auth key from https://login.tailscale.com/admin/settings/keys
# (a reusable key is fine; the node persists its state in a volume).
TS_AUTHKEY=
TS_HOSTNAME=kestravault
