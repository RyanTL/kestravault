# The pnpm version is provided by the toolchain (Homebrew / CI setup-node),
# so don't let pnpm try to self-switch based on the packageManager field.
manage-package-manager-versions=false

# A scaffold has a small, well-behaved dependency tree; don't fail installs on
# upstream peer-range noise. Revisit if we want stricter guarantees later.
strict-peer-dependencies=false
