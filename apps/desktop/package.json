{
  "name": "@kestravault/desktop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "description": "KestraVault desktop app: Electron + React (DOM) + CodeMirror 6. Three-pane shell — see README.",
  "author": "KestraVault contributors",
  "homepage": "https://github.com/RyanTL/kestravault",
  "repository": {
    "type": "git",
    "url": "https://github.com/RyanTL/kestravault.git",
    "directory": "apps/desktop"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json",
    "lint": "eslint .",
    "test": "vitest run",
    "build:unpack": "electron-vite build && electron-builder --dir",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@kestravault/core": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@supabase/supabase-js": "^2.45.0",
    "lucide-react": "^1.22.0",
    "ws": "^8.18.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "codemirror": "^6.0.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
